# ---- Database (Postgres) ----
# Pooled connection for the app (PgBouncer / Neon / Supabase pooler).
DATABASE_URL="postgresql://user:pass@host:6543/tessera?pgbouncer=true&connection_limit=1"
# Direct connection for migrations only (no pooler).
DIRECT_URL="postgresql://user:pass@host:5432/tessera"

# ---- Auth (Auth.js / NextAuth v5) ----
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-me"
AUTH_URL="http://localhost:3000"
# Email magic-link provider (any SMTP). Optional in dev — see lib/auth.ts dev fallback.
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="Tessera <hello@glyph.cards>"

# ---- Object storage (S3 / Cloudflare R2) for hero art + venue logos ----
# Leave STORAGE_DRIVER=local for dev (writes to ./public/uploads).
STORAGE_DRIVER="local"            # "local" | "s3"
S3_REGION="auto"
S3_BUCKET="tessera-media"
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL="https://media.glyph.cards"  # CDN/public bucket base for reads

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
